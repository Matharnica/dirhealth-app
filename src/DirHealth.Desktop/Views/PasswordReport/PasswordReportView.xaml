<UserControl x:Class="DirHealth.Desktop.Views.PasswordReport.PasswordReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left panel -->
        <Border Grid.Column="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid Margin="16,24,16,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Password Expiry" FontSize="20" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,20" />

                <TextBlock Grid.Row="1" Text="EXPIRING WITHIN" FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                <ComboBox Grid.Row="2"
                          ItemsSource="{Binding DayOptions}"
                          SelectedItem="{Binding WithinDays}"
                          Margin="0,0,0,20">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Foreground="{DynamicResource TextPrimaryBrush}">
                                <Run Text="{Binding Mode=OneWay}" /><Run Text=" days" />
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <StackPanel Grid.Row="3">
                    <ProgressBar IsIndeterminate="True" Height="2" Margin="0,0,0,16"
                                 Background="Transparent" Foreground="{StaticResource AccentBrush}"
                                 BorderThickness="0"
                                 Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}" />

                    <TextBlock Text="STATUS" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,10" />

                    <Border Background="{DynamicResource BackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="12,10" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="{Binding Users.Count, Mode=OneWay}" FontSize="28"
                                       FontWeight="Black" Foreground="{StaticResource WarningBrush}" />
                            <TextBlock Text="users expiring" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{Binding StatusMessage}" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap" Margin="0,4,0,0"
                               Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibility}}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Right panel: table -->
        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="Users" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" />
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="CSV" Style="{StaticResource SecondaryButton}"
                            Command="{Binding ExportCsvCommand}"
                            Padding="10,4" FontSize="11" Margin="0,0,6,0" />
                    <Button Content="PDF" Style="{StaticResource SecondaryButton}"
                            Command="{Binding ExportPdfCommand}"
                            Padding="10,4" FontSize="11" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                <ListView ItemsSource="{Binding Users}" Background="Transparent" BorderThickness="0">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Name"       Width="180" DisplayMemberBinding="{Binding DisplayName}" />
                            <GridViewColumn Header="Username"   Width="140" DisplayMemberBinding="{Binding SamAccountName}" />
                            <GridViewColumn Header="Email"      Width="200" DisplayMemberBinding="{Binding Email}" />
                            <GridViewColumn Header="Expires in" Width="120">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock FontWeight="SemiBold">
                                            <TextBlock.Text>
                                                <Binding Path="DaysUntilPasswordExpiry" StringFormat="{}{0} days" />
                                            </TextBlock.Text>
                                            <TextBlock.Foreground>
                                                <Binding Path="DaysUntilPasswordExpiry"
                                                         Converter="{StaticResource DaysToExpiryColor}" />
                                            </TextBlock.Foreground>
                                        </TextBlock>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Last Changed" Width="140"
                                            DisplayMemberBinding="{Binding PasswordLastSet, StringFormat={}{0:dd.MM.yyyy}}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>

            <TextBlock Grid.Row="2" Margin="0,16,0,0" HorizontalAlignment="Center" FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Text="No users with passwords expiring in this window. ✓">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Users.Count, Mode=OneWay}" Value="0">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>
    </Grid>
</UserControl>
