<UserControl x:Class="DirHealth.Desktop.Views.Dashboard.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left panel -->
        <Border Grid.Column="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid Margin="20,24,20,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Title -->
                <TextBlock Grid.Row="0" Text="Dashboard" FontSize="20" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,24" />

                <!-- Score + Stats -->
                <StackPanel Grid.Row="1">
                    <TextBlock Text="COMPLIANCE SCORE" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,4" />
                    <TextBlock Text="{Binding ComplianceScore}" FontSize="52" FontWeight="Black"
                               Foreground="{StaticResource SuccessBrush}" LineHeight="52" />
                    <TextBlock Text="/ 100" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0" />

                    <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,16,0,16" />

                    <!-- Clickable stat rows -->
                    <Button Style="{StaticResource SecondaryButton}" Margin="0,0,0,6"
                            HorizontalContentAlignment="Stretch" Padding="10,8"
                            Command="{Binding OpenCategoryCommand}"
                            CommandParameter="InactiveUsers">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Inactive Users" FontSize="12"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Grid.Column="1" Text="{Binding InactiveUsersCount}"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource ErrorBrush}" />
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource SecondaryButton}" Margin="0,0,0,6"
                            HorizontalContentAlignment="Stretch" Padding="10,8"
                            Command="{Binding OpenCategoryCommand}"
                            CommandParameter="PasswordNeverExpires">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Password Issues" FontSize="12"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Grid.Column="1" Text="{Binding PasswordIssuesCount}"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource WarningBrush}" />
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource SecondaryButton}" Margin="0,0,0,0"
                            HorizontalContentAlignment="Stretch" Padding="10,8"
                            Command="{Binding OpenCategoryCommand}"
                            CommandParameter="EmptyGroups">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Group Issues" FontSize="12"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Grid.Column="1" Text="{Binding GroupIssuesCount}"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                        </Grid>
                    </Button>

                    <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,16,0,16" />

                    <TextBlock Text="LAST SCAN" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                    <TextBlock Text="{Binding LastScanTime}"
                               Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" />
                    <TextBlock Text="{Binding StatusMessage}" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap" Margin="0,4,0,0" />
                </StackPanel>

                <!-- Buttons at bottom -->
                <StackPanel Grid.Row="2">
                    <ProgressBar IsIndeterminate="True" Height="2" Margin="0,0,0,10"
                                 Background="Transparent" Foreground="{StaticResource AccentBrush}"
                                 BorderThickness="0"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" />
                    <Button Style="{StaticResource PrimaryButton}" Content="▶  Run Scan"
                            Command="{Binding RunScanCommand}" Margin="0,0,0,8"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
                    <Button Style="{StaticResource SecondaryButton}"
                            Content="Full Report PDF"
                            Command="{Binding ExportFullReportCommand}"
                            FontSize="12" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Right panel -->
        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Findings" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
                <Button Grid.Column="1" Style="{StaticResource PrimaryButton}"
                        Content="View all →" Padding="12,4" FontSize="12"
                        Command="{Binding OpenCategoryCommand}"
                        CommandParameter=""
                        Visibility="{Binding FindingsCount, Converter={StaticResource NonZeroToVisibility}}" />
            </Grid>

            <!-- Findings list -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <ItemsControl ItemsSource="{Binding Findings}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource FindingRow}"
                                        Command="{Binding DataContext.OpenFindingCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontSize="13"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                                            <TextBlock Text="{Binding Description}" FontSize="11"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Margin="0,3,0,0" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                    VerticalAlignment="Center" Margin="12,0,0,0">
                                            <Border CornerRadius="4" Padding="8,3" Margin="0,0,8,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#374151" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Severity}" Value="High">
                                                                <Setter Property="Background" Value="#7F1D1D" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Severity}" Value="Medium">
                                                                <Setter Property="Background" Value="#78350F" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Severity}" FontSize="11">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Severity}" Value="High">
                                                                    <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Severity}" Value="Medium">
                                                                    <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                            <TextBlock Text="{Binding Count}" FontSize="12"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,4,0" />
                                            <TextBlock Text="affected  →" FontSize="12"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Margin="0,24,0,0" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Text="No findings — your AD looks healthy! ✓">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FindingsCount}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </ScrollViewer>

            <!-- Score trend chart -->
            <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,16,0,0" Padding="16,12"
                    Visibility="{Binding ScoreHistory.Count, Converter={StaticResource NonZeroToVisibility}, Mode=OneWay}">
                <StackPanel>
                    <TextBlock Text="Score Trend" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8" />
                    <Canvas x:Name="TrendChart" Height="72"
                            SizeChanged="TrendChart_SizeChanged" />
                </StackPanel>
            </Border>
            <!-- Changes since last scan -->
            <Border Grid.Row="3" Style="{StaticResource Card}" Margin="0,12,0,0" Padding="16,12"
                    Visibility="{Binding HasDiff, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Changes since last scan" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Grid.Column="1" FontSize="12" FontWeight="SemiBold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{Binding LastDiff.ScoreDelta, StringFormat='Score: +{0} ▲'}" />
                                    <Setter Property="Foreground" Value="#4ADE80"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding LastDiff.ScoreDelta, Converter={StaticResource IsNegativeConverter}}" Value="True">
                                            <Setter Property="Text" Value="{Binding LastDiff.ScoreDelta, StringFormat='Score: {0} ▼'}"/>
                                            <Setter Property="Foreground" Value="#E05555"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding LastDiff.ScoreDelta}" Value="0">
                                            <Setter Property="Text" Value="Score: unchanged"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <!-- Resolved findings -->
                    <ItemsControl ItemsSource="{Binding LastDiff.ResolvedFindings}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock FontSize="11" Foreground="#4ADE80" Margin="0,1"
                                           Text="{Binding Title, StringFormat='✓ Resolved: {0}'}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- New findings -->
                    <ItemsControl ItemsSource="{Binding LastDiff.NewFindings}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock FontSize="11" Foreground="#E05555" Margin="0,1"
                                           Text="{Binding Title, StringFormat='⚠ New: {0}'}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Changed counts -->
                    <ItemsControl ItemsSource="{Binding LastDiff.ChangedFindings}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock FontSize="11" Margin="0,1">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#4ADE80"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Delta, Converter={StaticResource IsNegativeConverter}}" Value="False">
                                                    <Setter Property="Foreground" Value="#E05555"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    <Run Text="{Binding Finding.Title, Mode=OneWay}"/>
                                    <Run Text="{Binding Delta, StringFormat=': {0:+#;-#;0}', Mode=OneWay}"/>
                                </TextBlock>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
