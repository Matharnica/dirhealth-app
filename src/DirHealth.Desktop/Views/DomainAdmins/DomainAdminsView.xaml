<UserControl x:Class="DirHealth.Desktop.Views.DomainAdmins.DomainAdminsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left panel -->
        <Border Grid.Column="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,1,0"
                Padding="16,20,16,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Domain Admins" FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,20" />

                <StackPanel Grid.Row="1">
                    <Border Background="{DynamicResource BackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="12,10" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="MEMBERS" FontSize="9" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <TextBlock FontSize="28" FontWeight="Black">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="—" />
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Group}" Value="{x:Null}">
                                                <Setter Property="Text" Value="—" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                                <TextBlock.Text>
                                    <Binding Path="Group.Members.Count" Mode="OneWay" FallbackValue="—" />
                                </TextBlock.Text>
                            </TextBlock>
                            <TextBlock Text="in Domain Admins group" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Border>

                    <Button Style="{StaticResource PrimaryButton}"
                            Content="↻  Refresh" Command="{Binding LoadCommand}"
                            IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}"
                            HorizontalAlignment="Stretch" Margin="0,0,0,12" />

                    <ProgressBar IsIndeterminate="True" Height="2"
                                 Background="Transparent" Foreground="{StaticResource AccentBrush}"
                                 BorderThickness="0"
                                 Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}" />

                    <TextBlock Text="{Binding StatusMessage}" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap" Margin="0,8,0,0"
                               Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibility}}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Right: members list -->
        <Grid Grid.Column="1" Margin="24,20,24,20">
            <!-- Empty / not-loaded state -->
            <TextBlock Text="Click Refresh to load Domain Admins."
                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13"
                       HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Group}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Group}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <!-- Warning banner if many admins -->
                    <Border CornerRadius="8" Padding="14,10" Margin="0,0,0,16"
                            Background="#7F1D1D"
                            Visibility="{Binding Group.Members.Count, Converter={StaticResource NonZeroToVisibility}, Mode=OneWay}">
                        <TextBlock FontSize="12" Foreground="#FCA5A5" TextWrapping="Wrap">
                            <Run Text="⚠  " FontWeight="Bold"/>
                            <Run Text="{Binding Group.Members.Count, Mode=OneWay}"/>
                            <Run Text=" member(s) have Domain Admin privileges. Review regularly and keep this list minimal."/>
                        </TextBlock>
                    </Border>

                    <Border Style="{StaticResource Card}" Padding="0">
                        <ItemsControl ItemsSource="{Binding Group.Members}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="0,0,0,1" Padding="16,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Type badge -->
                                            <Border CornerRadius="4" Padding="8,3" Margin="0,0,12,0"
                                                    VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#1D3461" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ObjectType}" Value="Group">
                                                                <Setter Property="Background" Value="#312E81" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ObjectType}" Value="Computer">
                                                                <Setter Property="Background" Value="#1E3A2F" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding ObjectType}" FontSize="10"
                                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                            </Border>

                                            <!-- Name + login -->
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           FontWeight="SemiBold" FontSize="13" />
                                                <TextBlock Text="{Binding SamAccountName}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           FontSize="11" />
                                            </StackPanel>

                                            <!-- DN -->
                                            <TextBlock Grid.Column="2" Text="{Binding DistinguishedName}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="10" FontFamily="Consolas"
                                                       VerticalAlignment="Center" MaxWidth="320"
                                                       TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
