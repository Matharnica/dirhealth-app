<UserControl x:Class="DirHealth.Desktop.Views.Settings.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left nav panel -->
        <Border Grid.Column="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid Margin="16,24,16,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Settings" FontSize="20" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="4,0,0,20" />

                <!-- Nav items -->
                <StackPanel Grid.Row="1" Margin="0,0,0,20">
                    <Button Command="{Binding SelectSectionCommand}" CommandParameter="Connection"
                            HorizontalContentAlignment="Left" Padding="10,9"
                            Margin="0,0,0,2">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="Connection">
                                        <Setter Property="Background" Value="{DynamicResource NavHoverBrush}" />
                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock>
                            <Run Text="🔌  " /><Run Text="Connection" />
                        </TextBlock>
                    </Button>
                    <Button Command="{Binding SelectSectionCommand}" CommandParameter="Schedule"
                            HorizontalContentAlignment="Left" Padding="10,9"
                            Margin="0,0,0,2">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="Schedule">
                                        <Setter Property="Background" Value="{DynamicResource NavHoverBrush}" />
                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock>
                            <Run Text="⏱  " /><Run Text="Scheduled Scan" />
                        </TextBlock>
                    </Button>
                    <Button Command="{Binding SelectSectionCommand}" CommandParameter="Updates"
                            HorizontalContentAlignment="Left" Padding="10,9"
                            Margin="0,0,0,2">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="Updates">
                                        <Setter Property="Background" Value="{DynamicResource NavHoverBrush}" />
                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock>
                            <Run Text="🔄  " /><Run Text="Updates" />
                        </TextBlock>
                    </Button>
                    <Button Command="{Binding SelectSectionCommand}" CommandParameter="About"
                            HorizontalContentAlignment="Left" Padding="10,9">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="About">
                                        <Setter Property="Background" Value="{DynamicResource NavHoverBrush}" />
                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock>
                            <Run Text="ℹ  " /><Run Text="About" />
                        </TextBlock>
                    </Button>
                </StackPanel>

                <!-- Status boxes -->
                <StackPanel Grid.Row="2" VerticalAlignment="Bottom">
                    <Border Background="{DynamicResource BackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="10,8">
                        <StackPanel>
                            <TextBlock Text="CONNECTION" FontSize="9" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,3" />
                            <TextBlock Text="{Binding ConnectionInfo}" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Right: form content -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,28,32,28">

                <!-- Connection section -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSection}" Value="Connection">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock Text="Active Directory" FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4" />
                    <TextBlock Text="Configure the connection to your domain"
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                               Margin="0,0,0,24" />

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="DOMAIN" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                            <TextBox Style="{StaticResource DarkTextBox}"
                                     Text="{Binding Domain, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="USERNAME" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                            <TextBox Style="{StaticResource DarkTextBox}"
                                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="PASSWORD" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                    <PasswordBox Style="{StaticResource DarkPasswordBox}"
                                 x:Name="PasswordInput" Margin="0,0,0,20"
                                 PasswordChanged="PasswordInput_PasswordChanged" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource SecondaryButton}"
                                Content="Test Connection"
                                Command="{Binding TestConnectionCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
                        <Button Grid.Column="2" Style="{StaticResource PrimaryButton}"
                                Content="Save" Command="{Binding SaveCommand}" />
                        <TextBlock Grid.Column="3" Margin="12,0,0,0" FontSize="12"
                                   Text="{Binding ConnectionTestResult}" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ConnectionTestPassed}" Value="False">
                                            <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                               Foreground="{StaticResource SuccessBrush}" Margin="0,8,0,0"
                               Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibility}}" />
                </StackPanel>

                <!-- Schedule section -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSection}" Value="Schedule">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock Text="Scheduled Scan" FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4" />
                    <TextBlock Text="Automatically scan Active Directory in the background"
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                               Margin="0,0,0,24" />

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Auto-scan in background" FontSize="13"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="Runs a full AD scan on the configured interval"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"
                                       Margin="0,3,0,0" />
                        </StackPanel>
                        <CheckBox Grid.Column="1" IsChecked="{Binding AutoScanEnabled}"
                                  VerticalAlignment="Center" />
                    </Grid>

                    <TextBlock Text="⚠ The app must remain open for scheduled scans to run."
                               FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,16" FontStyle="Italic"
                               Visibility="{Binding AutoScanEnabled, Converter={StaticResource BoolToVisibility}}" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Scan interval" FontSize="13"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1" Width="130"
                                  ItemsSource="{Binding ScanIntervalOptions}"
                                  SelectedItem="{Binding AutoScanIntervalHours}"
                                  IsEnabled="{Binding AutoScanEnabled}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Foreground="{DynamicResource TextPrimaryBrush}">
                                        <Run Text="{Binding Mode=OneWay}" /><Run Text=" hours" />
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>
                </StackPanel>

                <!-- Updates section -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSection}" Value="Updates">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock Text="Updates" FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4" />
                    <TextBlock Text="Check for new versions of DirHealth"
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                               Margin="0,0,0,24" />

                    <Border Background="{DynamicResource BackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="16,12" Margin="0,0,0,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="INSTALLED VERSION" FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,3" />
                                <TextBlock FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}">
                                    <Run Text="v" /><Run Text="{Binding CurrentVersion, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>
                            <Button Grid.Column="1" Style="{StaticResource SecondaryButton}"
                                    Content="Check for Updates"
                                    Command="{Binding CheckForUpdatesCommand}"
                                    IsEnabled="{Binding IsCheckingForUpdates, Converter={StaticResource InverseBool}}"
                                    VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <TextBlock Text="{Binding UpdateStatusText}" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Visibility="{Binding UpdateStatusText, Converter={StaticResource StringToVisibility}}" />
                </StackPanel>

                <!-- About section -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSection}" Value="About">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock Text="About DirHealth" FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4" />
                    <TextBlock Text="Free Active Directory health scanner"
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                               Margin="0,0,0,24" />

                    <Border Background="{DynamicResource BackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="16,14" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="VERSION" FontSize="9" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,3" />
                            <TextBlock FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}">
                                <Run Text="v" /><Run Text="{Binding CurrentVersion, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource BackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="16,14" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="LICENSE" FontSize="9" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,3" />
                            <TextBlock FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}">
                                MIT License · Copyright © 2026 Stefan Moseler
                            </TextBlock>
                            <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"
                                       TextWrapping="Wrap">
                                Free to use, modify, and distribute. Attribution appreciated.
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource BackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="16,14">
                        <StackPanel>
                            <TextBlock Text="LINKS" FontSize="9" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8" />
                            <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}">
                                <Hyperlink NavigateUri="https://dirhealth.app"
                                           RequestNavigate="Hyperlink_RequestNavigate">
                                    dirhealth.app
                                </Hyperlink>
                                <Run Text="  ·  " />
                                <Hyperlink NavigateUri="https://github.com/matharnica/dirhealth"
                                           RequestNavigate="Hyperlink_RequestNavigate">
                                    GitHub
                                </Hyperlink>
                                <Run Text="  ·  " />
                                <Hyperlink NavigateUri="https://ko-fi.com/matharnica"
                                           RequestNavigate="Hyperlink_RequestNavigate">
                                    Support on Ko-fi
                                </Hyperlink>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
